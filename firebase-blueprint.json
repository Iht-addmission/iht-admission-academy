{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with role and enrollment status",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "teacher", "admin"] },
        "isPaid": { "type": "boolean" },
        "enrolledCourses": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Class": {
      "title": "Class",
      "description": "Educational class session info",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "teacher": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "durationMinutes": { "type": "number" },
        "meetLink": { "type": "string" },
        "courseId": { "type": "string" },
        "status": { "type": "string", "enum": ["upcoming", "live", "completed"] },
        "materials": { "type": "array", "items": { "type": "object", "properties": { "title": { "type": "string" }, "url": { "type": "string" } } } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "teacher", "startTime", "meetLink", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/classes/{classId}": {
      "schema": "Class",
      "description": "Class session records"
    }
  }
}
